# Copiez ce fichier en ".env" et personnalisez les valeurs avant le déploiement.

# Port d'écoute du serveur (Railway/Render définissent souvent PORT automatiquement)
PORT=3000

# Clé secrète utilisée pour signer les sessions (JWT).
# Si vous ne la définissez pas, une clé aléatoire est générée automatiquement
# et enregistrée dans data/jwt-secret.txt au premier démarrage (suffisant en
# général, mais définir la vôtre est recommandé sur un hébergement partagé).
JWT_SECRET=change-moi-avec-une-longue-chaine-aleatoire

# Identifiants du tout premier compte administrateur, créés automatiquement
# au tout premier démarrage (seulement s'il n'existe encore aucun utilisateur).
ADMIN_USERNAME=LUCRS
ADMIN_PASSWORD=1234
